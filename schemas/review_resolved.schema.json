{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review Resolved",
  "type": "object",
  "required": ["task_id", "screen_id", "resolved_at", "items"],
  "properties": {
    "task_id": { "type": "string" },
    "screen_id": { "type": "string" },
    "resolved_at": { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question_id", "status"],
        "properties": {
          "question_id": { "type": "string" },
          "original_question": { "type": "string" },
          "user_answer": { "type": "string" },
          "status": { "type": "string", "enum": ["resolved", "pending", "skipped"] },
          "applied_to": { "type": "string" }
        }
      }
    }
  }
}
