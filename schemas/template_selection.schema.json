{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Template Selection",
  "type": "object",
  "required": ["screen_id", "screen_type", "selected_template", "confidence"],
  "properties": {
    "screen_id": { "type": "string" },
    "screen_type": { "type": "string" },
    "selected_template": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "manual_required": { "type": "boolean", "default": false },
    "skeleton_files": {
      "type": "object",
      "properties": {
        "html": { "type": "string" },
        "xml": { "type": "string" },
        "controller": { "type": ["string", "null"] },
        "service": { "type": ["string", "null"] }
      }
    },
    "required_functions": { "type": "array", "items": { "type": "string" } },
    "required_listeners": { "type": "array", "items": { "type": "string" } }
  }
}
